<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Your Profile</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>
body {
  font-family: Arial, sans-serif;
  background: #f6f6f6;
  margin: 0;
  padding: 20px;
}

.container {
  max-width: 900px;
  margin: auto;
  text-align: center;
}

.profile {
  background: white;
  padding: 18px;
  border-radius: 12px;
  width: 240px;
  margin: 0 auto 20px auto;
}

.profile img {
  width: 160px;
  height: 160px;
  border-radius: 50%;
  object-fit: cover;
}

.profile-name {
  margin-top: 10px;
  font-size: 16px;
  font-weight: 600;
}

video {
  width: 480px;
  margin-top: 20px;
}
</style>
</head>

<body>
<div class="container">

<h2>People who accessed your profile</h2>

<div class="profile">
  <img src="./Jack.png" alt="Jack">
  <div class="profile-name">Jack</div>
</div>

<video controls>
  https://iu.co1.qualtrics.com/ControlPanel/File.php?F=F_VvSGlUTYJpWUiYf
  Your browser does not support the video tag.
</video>

</div>
</body>
</html>
